{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BridgeHop",
  "version": "1.2.3",
  "identifier": "org.bridgehop.app",
  "build": {
    "frontendDist": "../ui/build",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm --prefix ui run dev",
    "beforeBuildCommand": "npm --prefix ui run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "BridgeHop",
        "width": 1140,
        "height": 780,
        "minWidth": 360,
        "minHeight": 520,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "center2055",
    "homepage": "https://github.com/center2055/BridgeHop",
    "license": "GPL-3.0-or-later",
    "category": "Utility",
    "copyright": "Copyright © 2026 center2055. GPL-3.0-or-later.",
    "shortDescription": "Tor bridge reachability scanner",
    "longDescription": "BridgeHop tests whether Tor bridges are reachable from your network across all transport types, with built-in lists, live sources, scan history, and reliability tracking.",
    "licenseFile": "../LICENSE",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0"]
      }
    }
  }
}
